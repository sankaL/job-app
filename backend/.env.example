# Root .env.compose is canonical. Use this only for direct backend runs.
APP_ENV=development
APP_DEV_MODE=true
API_PORT=8000
DATABASE_URL=postgresql://postgres:resume-builder-local-postgres-password@localhost:54423/postgres
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173
SUPABASE_EXTERNAL_URL=http://localhost:54421
SUPABASE_AUTH_JWKS_URL=http://localhost:54421/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
EMAIL_NOTIFICATIONS_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
